# StartupSparta Environment Variables

# ============================================================================
# Supabase Configuration (Required)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================================
# Privy Authentication (Required)
# ============================================================================
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# ============================================================================
# Email Service - Resend (Required for Email Verification)
# ============================================================================
# Sign up at https://resend.com and get your API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Custom from email (defaults to verify@startupsparta.com)
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# ============================================================================
# Solana Configuration (Required)
# ============================================================================
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Or use devnet for testing:
# NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# ============================================================================
# Optional Configuration
# ============================================================================

# Rate Limiting (defaults in code if not set)
# VERIFICATION_RATE_LIMIT=5 # attempts per hour

# Node Environment
NODE_ENV=development

# ============================================================================
# Notes
# ============================================================================
# - DNS verification uses Node.js built-in dns module (no config needed)
# - Rate limiting is tracked in the database (no external service needed)
# - Never commit this file to version control (.gitignore should exclude it)
# - For production, set these in your deployment platform (Vercel, etc.)
