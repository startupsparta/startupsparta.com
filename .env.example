# StartupSparta Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# SOLANA CONFIGURATION
# =============================================================================
# Network: 'devnet' for development/testing, 'mainnet-beta' for production
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Solana RPC endpoint (public endpoint for devnet)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Helius RPC URL with API key for better reliability and rate limits
# Get your API key from https://helius.xyz
NEXT_PUBLIC_HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY_HERE
HELIUS_API_KEY=your_helius_api_key_here

# =============================================================================
# PRIVY AUTHENTICATION
# =============================================================================
# Get these from https://privy.io dashboard
# Create an app and enable Wallet + Google login methods
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here
PRIVY_APP_SECRET=your_privy_app_secret_here

# =============================================================================
# SUPABASE DATABASE
# =============================================================================
# Get these from https://supabase.com project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# =============================================================================
# SMART CONTRACT PROGRAM IDS
# =============================================================================
# Leave empty until you deploy the Anchor programs
# After deployment, add the program IDs from 'anchor deploy' output
NEXT_PUBLIC_BONDING_CURVE_PROGRAM_ID=
NEXT_PUBLIC_TOKEN_FACTORY_PROGRAM_ID=

# =============================================================================
# PLATFORM CONFIGURATION
# =============================================================================
# Wallet address that receives platform trading fees (1% of all trades)
# Use your Phantom wallet address
NEXT_PUBLIC_PLATFORM_WALLET=your_wallet_address_here

# =============================================================================
# LAUNCH MODE & DEV BYPASS
# =============================================================================
# Controls whether the home page shows the waitlist gate or the full dashboard.
# Values: 'waitlist' (gate enabled) | 'open' (full dashboard for everyone)
# In production set this to 'waitlist'; in development it defaults to 'open'.
NEXT_PUBLIC_LAUNCH_MODE=open

# Secret token that lets developers bypass the waitlist gate on any deployment.
# Set this in Vercel → Settings → Environment Variables (Preview + Production).
# Access the dashboard by visiting:
#   https://<your-deployment-url>/api/dev-access?token=<DEV_BYPASS_TOKEN>
# A secure HttpOnly cookie is set (valid 7 days) and you are redirected to the full dashboard.
DEV_BYPASS_TOKEN=your_secret_dev_token_here
